# Copy this to .env or use ecosystem.config.js (recommended for PM2)
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

NODE_ENV=production
PORT=5000

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/DATABASE_NAME

# Session encryption secret — must be long and random (required)
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Object Storage — only needed for CMS hero image uploads
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=.private
PUBLIC_OBJECT_SEARCH_PATHS=public
