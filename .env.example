# Copy this file to .env for local development
# On Railway, set these in the Variables tab (DATABASE_URL and PORT are set automatically)

# Required
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME
SESSION_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NODE_ENV=production

# Optional
PORT=5000

# Object Storage — only needed for CMS hero image uploads
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id
PRIVATE_OBJECT_DIR=.private
PUBLIC_OBJECT_SEARCH_PATHS=public
